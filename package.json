{
  "name": "@vaultbase/mcp",
  "version": "0.1.0",
  "description": "Stdio↔HTTP bridge for the Vaultbase MCP server — connect Claude Desktop / Cursor / any MCP client to a remote Vaultbase deployment.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "vaultbase-mcp": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "vaultbaseServerCompat": ">=0.10 <2.0",
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "keywords": [
    "vaultbase",
    "mcp",
    "model-context-protocol",
    "claude",
    "ai-agent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.13",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0"
  },
  "sideEffects": false
}
